# ---------------------------------------------------------------
# LYNK 3D Website — environment variables
# Copy this file to ".env" and fill in real values.
# .env is gitignored and automatically loaded by `netlify dev`.
# In production, set these in Netlify dashboard → Site settings → Environment variables.
# ---------------------------------------------------------------

# Mollie — create account at https://www.mollie.com, grab a test key from the dashboard
# Test keys start with "test_", live keys with "live_"
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Mail gaat via BIM LYNK relay-function (hergebruikt Graph API setup daar,
# zodat Lynk3D geen eigen Azure credentials nodig heeft)
MAIL_RELAY_URL=https://www.bimlynk.com/.netlify/functions/mail-relay
MAIL_RELAY_SECRET=generate-with-openssl-rand-hex-32
NOTIFICATION_EMAIL=info@cvlsolutions.nl

# Telegram push — reuse LYNKYUWANA bot, get chat id from @userinfobot
TELEGRAM_BOT_TOKEN=xxxxxxxx:yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
TELEGRAM_ADMIN_CHAT_ID=123456789
